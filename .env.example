# Dev bypass — set to 'true' to auto-login as founder (development only)
VITE_DEV_AUTO_LOGIN="false"

# Gemini API — required for AI lead discovery features
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Supabase — required for auth and data persistence
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Anthropic API — required for the What's On AI Agent (/whats-on-agent)
VITE_ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Stripe — required for supporter/subscription payments
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_your_stripe_key_here"
# Payment Link codes from Stripe Dashboard → Payment Links (the part after buy.stripe.com/)
VITE_STRIPE_PRICE_SUPPORTER="your_payment_link_code_here"
VITE_STRIPE_PRICE_FEATURED="your_payment_link_code_here"

# Discord — required for Community tab
# Get these from discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here       # server-side only — no VITE_ prefix
DISCORD_SERVER_ID=your_discord_server_id_here        # server-side reference
DISCORD_CLIENT_ID=your_discord_client_id_here        # server-side reference
VITE_DISCORD_SERVER_ID=your_discord_server_id_here   # client-side — used by Discord Widget API
